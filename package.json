{
  "name": "ud3-madoka",
  "version": "1.0.0",
  "description": "Puella Magi Madoka Magica - Express MongoDB app",
  "main": "index.js",
  "scripts": {
    "test": "mocha test/*.test.js --require test/setup.js --timeout 10000",
    "test:coverage": "nyc npm test",
    "start": "node index.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.5",
    "morgan": "^1.10.1",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "sinon": "^21.0.1",
    "supertest": "^7.2.2"
  },
  "nyc": {
    "include": [
      "app.js",
      "db.js",
      "index.js",
      "models/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js"
    ],
    "exclude": [
      "test/**"
    ],
    "reporter": [
      "text",
      "lcov"
    ]
