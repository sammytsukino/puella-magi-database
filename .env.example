JWT_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# MongoDB (local, CI o Atlas en producción)
MONGO_URI=mongodb://localhost:27017/madokadb

# Render asigna PORT automáticamente; en local usa 8080 por defecto
PORT=8080

# En Render usar NODE_ENV=prod para logs Morgan en formato combined
NODE_ENV=development
